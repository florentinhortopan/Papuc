{
  "name": "papuc",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @papuc/web dev",
    "build": "pnpm --filter @papuc/web build",
    "start": "pnpm --filter @papuc/web start",
    "web": "pnpm --filter @papuc/web",
    "core": "pnpm --filter @papuc/core",
    "mobile": "pnpm --filter @papuc/mobile",
    "test": "pnpm --filter @papuc/core test",
    "typecheck": "pnpm --filter @papuc/web typecheck && pnpm --filter @papuc/core typecheck",
    "lint": "pnpm --filter @papuc/web lint"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.3.12",
      "@types/react-dom": "18.3.1"
    }
  }
}
