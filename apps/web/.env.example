# --- Public (sent to the browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Server-only ---
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Real-estate provider — set ONE.
# Preferred: HasData (Zillow scraper). Get a key at https://app.hasdata.com.
# Each scout costs ~5 credits per 25 candidates.
HASDATA_API_KEY=

# Legacy fallback. Used only if HASDATA_API_KEY is empty.
REALESTATEAPI_KEY=

# Any random string. Vercel Cron sends this in the Authorization header.
CRON_SECRET=replace-me-with-random-string
